---
import { Font } from "astro:assets";

import Links from "../components/Links.astro";
import Authors from "../components/Authors.astro";
import Notes from "../components/Notes.astro";
import type { Author, Note, Link } from "../types/types";

import Table from "../components/Table.astro";

import "../styles/global.css";
import "katex/dist/katex-swap.css";

import { Content, frontmatter } from "../paper.mdx";

interface Frontmatter {
  title: string;
  subtitle?: string;
  institution?: string;
  authors: Author[];
  conference?: string;
  notes?: Note[];
  links?: Link[];
  description?: string;
  favicon: string;
  thumbnail?: string;
  theme?: "device" | "light" | "dark";
}

const {
  title,
  subtitle,
  institution,
  authors,
  conference,
  notes,
  links,
  description,
  favicon,
  thumbnail,
  theme = "device",
} = frontmatter as Frontmatter;

const baseUrl = import.meta.env.BASE_URL;
const prefix = baseUrl.endsWith("/") ? baseUrl : baseUrl + "/";
---

<!doctype html>
<html class="bg-white dark:bg-zinc-900" lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    {description && <meta name="description" content={description} />}
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href={prefix + favicon} />

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    {thumbnail && <meta property="og:image" content={prefix + thumbnail} />}

    <Font
      cssVariable="--font-noto-sans"
      preload={[{ subset: "latin", style: "normal" }]}
    />

    <title>{title}</title>
  </head>
  <body
    class="prose prose-base sm:prose-lg prose-zinc dark:prose-invert prose-a:text-blue-500 prose-a:dark:text-blue-300 prose-a:no-underline prose-a:hover:underline prose-a:font-normal prose-code:bg-zinc-200 prose-code:dark:bg-zinc-800 prose-code:text-zinc-800 prose-code:dark:text-zinc-200 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-medium prose-code:before:content-none prose-code:after:content-none max-w-none pb-6 font-(family-name:--font-noto-sans)"
  >
    <div class="not-prose mb-12 w-full border-b border-zinc-200 dark:border-zinc-800">
      <div class="mx-auto flex max-w-[64rem] items-center px-6 py-4">
        <a href="https://aiot.snu.ac.kr/home" class="inline-flex items-center gap-3">
          <img
            src={prefix + "aiot-logo.png"}
            alt="AIoT Lab, Seoul National University"
            class="h-14 w-auto"
          />
          <span class="text-lg font-semibold text-zinc-700 dark:text-zinc-200">AIoT Lab</span>
        </a>
      </div>
    </div>

    <header class="mx-auto mb-12 max-w-[52rem] px-6 text-center">
      <h1 class="text-3xl sm:text-5xl font-bold text-[#1e3a8a] dark:text-blue-400">
        {title}
      </h1>
      {
        subtitle && (
          <p class="mt-3 mb-5 text-lg sm:text-2xl font-medium text-zinc-700 dark:text-zinc-200">
            {subtitle}
          </p>
        )
      }
      <div class="flex flex-col items-center gap-4">
        <Authors authors={authors} />
        {institution && <div class="text-lg">{institution}</div>}
        {conference && <div>{conference}</div>}
        {notes && <Notes notes={notes} />}
        {links && <Links links={links} />}
      </div>
    </header>
    <main>
      <Content components={{ table: Table }} />
    </main>
    <footer class="mx-auto max-w-[80rem] px-6 text-center">
      <p class="text-xs text-zinc-500 dark:text-zinc-400">
        This page was built using <a
          href="https://github.com/RomanHauksson/academic-project-astro-template"
          rel="nofollow">Roman Hauksson's template</a
        >, adapted from <a
          href="https://github.com/eliahuhorwitz/Academic-project-page-template"
          rel="nofollow">Eliahu Horwitz</a
        > and <a href="https://nerfies.github.io/" rel="nofollow"
          >Keunhong Park</a
        >. Licensed under <a
          href="http://creativecommons.org/licenses/by-sa/4.0/"
          rel="nofollow">CC BY-SA 4.0</a
        >.
      </p>
    </footer>
  </body>
</html>
