---
import { Icon } from "astro-icon/components";
import type { Link } from "../types/types";

interface Props {
  links: Link[];
}

const { links } = Astro.props;
---

<div class="not-prose inline-flex flex-row items-center gap-5 rounded-full bg-zinc-200 px-6 py-2.5 dark:bg-zinc-700">
  {
    links.map((link) => (
      <a
        href={link.url}
        class="flex flex-row items-center gap-2 whitespace-nowrap text-lg text-zinc-800 transition-colors hover:text-zinc-500 hover:no-underline dark:text-zinc-100 dark:hover:text-zinc-400"
      >
        {link.icon && <Icon name={link.icon} />}
        <span>{link.name}</span>
      </a>
    ))
  }
</div>
